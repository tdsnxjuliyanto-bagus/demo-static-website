---
import { experience } from '../../data/experience.js';

// "Jul 2021 - Aug 2023" -> "2021–2023" ; "May 2025 - Present" -> "2025"
const yearsOf = (period = '') => {
  const ys = String(period).match(/\d{4}/g) || [];
  if (!ys.length) return '';
  const a = ys[0];
  const b = ys[ys.length - 1];
  return a === b ? a : `${a}–${b}`;
};
const lastIndex = experience.length - 1;
---
<section id="pipeline" class="scene pipeline-scene" data-scene="pipeline">
  <div class="container pipeline-head">
    <span class="eyebrow reveal">the pipeline</span>
    <h2 class="scene-title reveal">A career, deployed in stages.</h2>
  </div>

  <!-- Desktop: viewport dipin, track meluncur horizontal. Mobile: stack vertikal. -->
  <div class="pipeline-viewport" data-pipeline-viewport>
    <div class="playhead" data-playhead aria-hidden="true">
      <span class="playhead-label" data-playhead-label>{yearsOf(experience[0]?.period)}</span>
    </div>
    <ol class="pipeline-track" data-pipeline-track>
      {experience.map((s, i) => (
        <li
          class:list={['stage', 'card', i === lastIndex && 'is-current']}
          data-stage
          data-index={i}
          data-years={i === lastIndex ? 'now' : yearsOf(s.period)}
        >
          <div class="stage-top">
            <span class="stage-dot" aria-hidden="true"></span>
            <span class="stage-phase">{s.phase}</span>
            <span class="stage-period">{s.period}</span>
          </div>
          <h3 class="stage-title">{s.title}</h3>
          <p class="stage-org">{s.org}</p>
          <p class="stage-impact">{s.impact}</p>
        </li>
      ))}
    </ol>
  </div>

  <div class="container">
    <div class="pipeline-rail" aria-hidden="true"><span data-pipeline-progress></span></div>
  </div>
</section>

<style>
  .pipeline-scene { overflow: hidden; }
  .pipeline-head { margin-bottom: 30px; }
  .pipeline-viewport { position: relative; }
  .pipeline-track {
    list-style: none; display: flex; gap: 20px; padding-inline: 24px;
    will-change: transform;
  }
  .stage {
    position: relative;
    flex: 0 0 320px; scroll-snap-align: center;
    display: flex; flex-direction: column; gap: 6px;
  }
  .stage-top { display: flex; align-items: center; gap: 10px; }
  .stage-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--border-strong); transition: background 0.4s var(--ease); }
  .stage.is-passed .stage-dot { background: var(--success); }
  .stage.is-active .stage-dot { background: var(--accent); box-shadow: 0 0 0 4px var(--accent-soft); }
  .stage-phase { font-family: var(--font-mono); font-size: 12px; color: var(--accent); }
  .stage-period { font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); margin-left: auto; }
  .stage-title { font-size: 1.2rem; margin-top: 6px; }
  .stage-org { color: var(--text-secondary); font-size: 14.5px; }
  .stage-impact { color: var(--text-secondary); font-size: 14px; margin-top: 6px; }

  /* Playhead: garis yang BERGERAK mengikuti progress scroll, berhenti tepat
     sebelum dot kartu yang sedang aktif. Labelnya membaca tahun kartu aktif,
     dan menjadi "now" saat tiba di jabatan terakhir. */
  .playhead {
    position: absolute; top: -12px; bottom: -12px; left: 0; width: 0;
    border-left: 1.5px dashed color-mix(in srgb, var(--accent) 55%, transparent);
    z-index: 2; pointer-events: none; will-change: transform;
  }
  .playhead-label {
    position: absolute; top: -22px; left: 50%; transform: translateX(-50%);
    font-family: var(--font-mono); font-size: 11px; color: var(--accent);
    white-space: nowrap;
  }
  .stage.is-current { border-color: color-mix(in srgb, var(--accent) 45%, var(--border)); }

  .pipeline-rail { height: 4px; border-radius: 2px; background: var(--border); margin-top: 34px; overflow: hidden; }
  .pipeline-rail > span { display: block; height: 100%; width: 0%; background: var(--accent); }

  /* Mobile: buang horizontal, jadi timeline vertikal */
  @media (max-width: 860px) {
    .pipeline-viewport { padding-inline: 0; }
    .pipeline-track {
      flex-direction: column; gap: 14px; padding-inline: 24px;
      transform: none !important; will-change: auto;
    }
    .stage { flex: 1 1 auto; }
    .playhead { display: none; }
    .pipeline-rail { display: none; }
  }
</style>
