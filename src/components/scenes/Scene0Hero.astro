---
import { profile } from '../../data/profile.js';
const chips = ['Cloud Architecture', 'Hybrid Infrastructure', 'Infrastructure as Code', 'Cloud Security', 'Cost Optimization'];
---
<section id="top" class="scene hero" data-scene="hero">
  <div class="blueprint-bg" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-copy">
      {profile.available && (
        <span class="avail" data-hero-el>
          <span class="dot" aria-hidden="true"></span>{profile.availableText}
        </span>
      )}
      <h1 class="hero-name" data-hero-name>{profile.fullName}</h1>
      <p class="hero-role" data-hero-el>{profile.role} &middot; {profile.roleSecondary}</p>
      <p class="hero-tag" data-hero-el>{profile.tagline}</p>
      <p class="lead" data-hero-el>{profile.summary}</p>
      <div class="hero-chips" data-hero-el>
        {chips.map((c) => <span class="pill">{c}</span>)}
      </div>
      <div class="hero-cta" data-hero-el>
        <a class="btn btn-primary" href="#projects">View my work</a>
        {profile.cvRequest !== false ? (
          <a class="btn btn-ghost" href="#console" data-cv-request>Request my CV</a>
        ) : (
          <a class="btn btn-ghost" href={profile.cvFile} download>Download CV</a>
        )}
      </div>
    </div>
  </div>
  <span class="scroll-hint" aria-hidden="true" data-hero-el>scroll to deploy &darr;</span>
</section>

<style>
  .hero { min-height: 100vh; display: flex; align-items: center; padding-block: 0; }
  .hero-grid { padding-top: 80px; }
  .hero-copy { max-width: 760px; }
  .avail {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 13px; color: var(--text-secondary);
    background: var(--surface); border: 1px solid var(--border);
    padding: 7px 14px; border-radius: 999px; margin-bottom: 26px;
  }
  .avail .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--success); box-shadow: 0 0 0 3px var(--success-soft); }
  .hero-name { font-size: clamp(2.6rem, 8vw, 5rem); letter-spacing: -0.03em; }
  .hero-role { font-family: var(--font-mono); color: var(--accent); margin-top: 10px; font-size: clamp(1rem, 2.2vw, 1.25rem); }
  .hero-tag { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.4rem, 3.5vw, 2.1rem); margin-top: 22px; max-width: 20ch; line-height: 1.15; }
  .lead { margin-top: 20px; }
  .hero-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 26px; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 30px; }
  .scroll-hint {
    position: absolute; bottom: 26px; left: 50%; transform: translateX(-50%);
    font-family: var(--font-mono); font-size: 12px; color: var(--text-muted);
  }
  @media (max-width: 640px) { .hero-grid { padding-top: 96px; } }
</style>
