---
import { profile } from '../../data/profile.js';
const { certs = {} } = Astro.props;
const stale = certs.stale;

const hasTranscript = profile.msLearnTranscript && !profile.msLearnTranscript.startsWith('[');

// Placeholder ('[...]') dan string kosong dianggap "tidak diisi".
const filled = (v) => typeof v === 'string' && v.trim() !== '' && !v.startsWith('[');

// 'YYYY-MM-DD' -> 'Mar 2025'. null bila tidak valid.
const fmt = (v) => {
  if (!filled(v)) return null;
  const d = new Date(v);
  if (Number.isNaN(d.getTime())) return null;
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' });
};

// "Earned Mar 2025 · Expires Mar 2026" / "· No expiration"
function meta(c) {
  const parts = [];
  const earned = fmt(c.earnedOn) || fmt(c.date);
  if (earned) parts.push(`Earned ${earned}`);

  let expired = false;
  if (filled(c.expiresOn)) {
    const exp = new Date(c.expiresOn);
    const expText = fmt(c.expiresOn);
    if (expText) {
      expired = !Number.isNaN(exp.getTime()) && exp.getTime() < Date.now();
      parts.push(`${expired ? 'Expired' : 'Expires'} ${expText}`);
    }
  } else if (earned && c.type !== 'applied-skill') {
    parts.push('No expiration');
  }
  return { text: parts.join(' · '), expired };
}

const prep = (list = []) => list.map((c) => ({ ...c, meta: meta(c) }));

const g = (key, id, title) => {
  const src = certs[key] || { shown: [], extra: [], total: 0 };
  return { id, title, shown: prep(src.shown), extra: prep(src.extra), total: src.total || 0 };
};

const groups = [
  g('accreditations', 'accreditations', 'Accreditations'),
  g('certifications', 'certifications', 'Certifications'),
  g('appliedSkills', 'applied-skills', 'Applied Skills'),
].filter((x) => x.shown.length || x.extra.length);
---
<section id="certs" class="scene" data-scene="certs">
  <div class="blueprint-bg" aria-hidden="true"></div>
  <div class="container">
    <span class="eyebrow reveal">credentials minted</span>
    <h2 class="scene-title reveal">Verified credentials.</h2>
    <p class="lead reveal" style="margin-top:16px">
      Fetched at build time — each badge links to its verification page.
    </p>

    {groups.length === 0 ? (
      <p class="reveal cert-empty">
        // isi username Credly di src/data/certs.js, atau daftar Microsoft Learn, untuk menampilkan kredensial.
      </p>
    ) : (
      groups.map((grp) => (
        <section class="cert-group" data-cert-group aria-labelledby={`cg-${grp.id}`}>
          <div class="cert-group-head reveal">
            <h3 class="cert-group-title" id={`cg-${grp.id}`}>{grp.title}</h3>
            <span class="cert-count">{grp.total}</span>
          </div>

          <div class="cert-grid" id={`cgrid-${grp.id}`}>
            {[...grp.shown, ...grp.extra].map((c, i) => {
              const link = filled(c.url) ? c.url : null;
              const Tag = link ? 'a' : 'div';
              const isExtra = i >= grp.shown.length;
              return (
                <Tag
                  class:list={['cert', 'card', 'reveal', isExtra && 'cert-extra']}
                  href={link}
                  target={link ? '_blank' : null}
                  rel={link ? 'noopener noreferrer' : null}
                >
                  {filled(c.image) ? (
                    <img class="cert-img" src={c.image} alt="" width="48" height="48" loading="lazy" decoding="async" />
                  ) : (
                    <span class="cert-badge" aria-hidden="true">
                      {c.type === 'accreditation' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="6"/><path d="M8.2 14.3 7 22l5-3 5 3-1.2-7.7"/></svg>
                      )}
                      {c.type === 'certification' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3h14a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/><path d="M8 7h8M8 11h5"/><path d="m9 16-1 5 4-2 4 2-1-5"/></svg>
                      )}
                      {c.type === 'applied-skill' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8z"/></svg>
                      )}
                    </span>
                  )}
                  <div class="cert-body">
                    <span class="cert-name">{c.name}</span>
                    <span class="cert-meta">{c.issuer}</span>
                    {c.meta.text && (
                      <span class={`cert-date${c.meta.expired ? ' is-expired' : ''}`}>{c.meta.text}</span>
                    )}
                  </div>
                  <span class="cert-src">{c.source}</span>
                </Tag>
              );
            })}
          </div>

          {grp.extra.length > 0 && (
            <button
              type="button"
              class="cert-more"
              data-cert-toggle
              data-count={grp.extra.length}
              aria-expanded="false"
              aria-controls={`cgrid-${grp.id}`}
            >
              <span data-cert-toggle-text>Show all {grp.total} badges</span>
              <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </button>
          )}
        </section>
      ))
    )}

    <div class="cert-actions reveal">
      {hasTranscript && (
        <a class="btn btn-ghost" href={profile.msLearnTranscript} target="_blank" rel="noopener noreferrer">
          View Microsoft Learn transcript
        </a>
      )}
      {stale && (
        <span class="cert-stale" title="Menampilkan daftar cadangan (fetch Credly gagal saat build).">
          showing cached list
        </span>
      )}
    </div>
  </div>
</section>

<style>
  .cert-empty { margin-top: 24px; color: var(--text-muted); font-family: var(--font-mono); font-size: 14px; }

  .cert-group { margin-top: 40px; }
  .cert-group-head { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .cert-group-title { font-size: 1.1rem; font-family: var(--font-display); }
  .cert-count {
    font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary);
    border: 1px solid var(--border); border-radius: 999px; padding: 1px 8px;
  }

  .cert-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .cert { display: flex; align-items: center; gap: 14px; }

  /* Badge tambahan: disembunyikan sampai tombol ditekan.
     Tanpa JS (html.no-js) semuanya tetap tampil -> konten tak pernah terkunci. */
  .cert-extra { display: none; }
  .cert-group.is-open .cert-extra { display: flex; }
  html.no-js .cert-extra { display: flex; }

  .cert-img { border-radius: 8px; flex: 0 0 auto; width: 48px; height: 48px; object-fit: contain; }
  .cert-badge {
    flex: 0 0 auto; width: 44px; height: 44px; border-radius: 10px;
    display: grid; place-items: center; background: var(--accent-soft); color: var(--accent);
  }
  .cert-badge svg { width: 22px; height: 22px; }
  .cert-body { display: flex; flex-direction: column; gap: 3px; flex: 1; min-width: 0; }
  .cert-name { font-weight: 500; font-size: 15px; }
  .cert-meta { font-size: 13px; color: var(--text-secondary); }
  .cert-date { font-family: var(--font-mono); font-size: 11.5px; color: var(--text-muted); }
  .cert-date.is-expired { color: #b45309; }
  :root[data-theme='dark'] .cert-date.is-expired { color: #fbbf24; }
  .cert-src { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); align-self: flex-start; }

  .cert-more {
    display: inline-flex; align-items: center; gap: 7px; margin-top: 14px;
    font-family: var(--font-mono); font-size: 13px; color: var(--accent);
    background: transparent; border: 1px dashed var(--border-strong);
    border-radius: var(--radius-sm); padding: 8px 14px;
    transition: border-color 0.2s var(--ease);
  }
  .cert-more:hover { border-color: var(--accent); }
  .cert-more .chev { width: 15px; height: 15px; transition: transform 0.25s var(--ease); }
  .cert-group.is-open .cert-more .chev { transform: rotate(180deg); }

  .cert-actions { display: flex; align-items: center; gap: 14px; margin-top: 30px; }
  .cert-stale { font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); }

  @media (max-width: 640px) { .cert-grid { grid-template-columns: 1fr; } }
</style>
