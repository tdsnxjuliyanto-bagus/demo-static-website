---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Scene0Hero from '../components/scenes/Scene0Hero.astro';
import Scene1About from '../components/scenes/Scene1About.astro';
import Scene2Expertise from '../components/scenes/Scene2Expertise.astro';
import Scene3Pipeline from '../components/scenes/Scene3Pipeline.astro';
import Scene4Projects from '../components/scenes/Scene4Projects.astro';
import Scene5Certs from '../components/scenes/Scene5Certs.astro';
import Scene6Console from '../components/scenes/Scene6Console.astro';
import { getCertifications } from '../lib/fetchCerts.mjs';
import { getProjects } from '../lib/fetchProjects.mjs';
import { resolveStats } from '../lib/stats.mjs';
import { stats as rawStats } from '../data/profile.js';
import { experience } from '../data/experience.js';

// Build-time: tarik sertifikat (Credly + MS Learn) dan repo GitHub.
// Keduanya graceful — kegagalan fetch tidak pernah mematikan build.
const certs = await getCertifications();
const { projects, stale: projectsStale } = await getProjects();

// Angka statistik dihitung dari data di atas, bukan diketik manual.
const stats = resolveStats(rawStats, { experience, certs, projects });
---
<Base>
  <Nav />
  <main id="main">
    <Scene0Hero />
    <Scene1About stats={stats} />
    <Scene2Expertise />
    <Scene3Pipeline />
    <Scene4Projects projects={projects} stale={projectsStale} />
    <Scene5Certs certs={certs} />
    <Scene6Console />
  </main>
  <Footer />
</Base>

<script>
  import '../scripts/story.js';
</script>
