---
import Base from '../layouts/Base.astro';
---
<Base>
  <main id="main" class="scene" style="min-height:80vh;display:flex;align-items:center">
    <div class="blueprint-bg" aria-hidden="true"></div>
    <div class="container" style="text-align:center">
      <p class="eyebrow" style="justify-content:center">404 · resource not found</p>
      <h1 style="font-size:clamp(2.4rem,7vw,4rem)">This route isn't deployed.</h1>
      <p class="lead" style="margin:16px auto 26px">The page you're looking for doesn't exist or has moved.</p>
      <a class="btn btn-primary" href="/">Back to home</a>
    </div>
  </main>
</Base>
